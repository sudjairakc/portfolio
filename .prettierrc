{
	"trailingComma": "none",
	"bracketSpacing": false,
	"arrowParens": "avoid",
	"singleQuote": false,
	"printWidth": 80,
	"useTabs": false,
	"tabWidth": 2,
	"semi": true,
	"plugins": ["prettier-plugin-astro"],
	"overrides": [
		{
			"files": "*.astro",
			"options": {
				"parser": "astro"
			}
		}
	]
}

