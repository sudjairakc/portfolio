---
import { educationInfo } from "../../data/portfolio";

const base = import.meta.env.BASE_URL;
---

<section id="education" class="section">
  <h2 class="text-3xl md:text-4xl font-bold mb-10 text-center reveal">Education</h2>

  <div class="space-y-6">
    {educationInfo.schools.map((school) => (
      <div
        class="reveal flex flex-col sm:flex-row gap-6 p-6 rounded-2xl transition-shadow hover:shadow-xl"
        style="background: var(--card-bg); box-shadow: var(--shadow); border: 1px solid var(--card-border);"
      >
        {school.logo && (
          <div class="shrink-0 flex items-start justify-center sm:justify-start">
            <img
              src={`${base}/images/${school.logo}`}
              alt={school.schoolName}
              class="w-20 h-20 rounded-xl object-contain"
              style="background: white; padding: 8px;"
              loading="lazy"
            />
          </div>
        )}

        <div class="flex-1">
          <h3 class="text-xl font-bold mb-1">{school.schoolName}</h3>
          <p class="font-semibold text-primary mb-1">{school.subHeader}</p>
          <p class="text-sm mb-1" style="color: var(--text-sub);">{school.duration}</p>
          <p class="text-sm font-medium mb-3">{school.desc}</p>
          {school.descBullets && (
            <ul class="space-y-1.5">
              {school.descBullets.map((bullet) => (
                <li class="flex items-start gap-2 text-sm" style="color: var(--text-sub);">
                  <span class="mt-0.5 text-primary shrink-0">▸</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
