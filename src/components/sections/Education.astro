---
import {educationInfo} from "../../data/portfolio";

const base = import.meta.env.BASE_URL;
---

<section id="education" class="section reveal">
  <!-- Heading block -->
  <div class="max-w-2xl">
    <span class="eyebrow">Education</span>
    <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight">
      Where I <span class="gradient-text">studied</span>
    </h2>
    <p class="text-sub mt-4 text-base leading-relaxed">
      The foundation behind the way I build.
    </p>
  </div>

  <!-- School cards -->
  <div class="mt-12 space-y-6">
    {
      educationInfo.schools.map((school, i) => (
        <article
          class:list={[
            "glass p-7 sm:p-9 transition duration-300 ease-out hover:-translate-y-1 hover:shadow-2xl",
            i % 2 === 0 ? "reveal-left" : "reveal-right"
          ]}
        >
          <div class="flex flex-col sm:flex-row gap-6">
            {school.logo && (
              <div class="shrink-0">
                <img
                  src={`${base}images/${school.logo}`}
                  alt={school.schoolName}
                  loading="lazy"
                  class="h-16 w-16 rounded-2xl object-contain bg-white p-2 shadow-sm ring-1 ring-black/5"
                />
              </div>
            )}

            <div class="flex-1 min-w-0">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h3 class="text-lg font-semibold tracking-tight">
                    {school.schoolName}
                  </h3>
                  <p class="text-sub mt-1 text-[0.95rem]">{school.subHeader}</p>
                </div>
                {school.duration && (
                  <span class="pill shrink-0 self-start whitespace-nowrap">
                    {school.duration}
                  </span>
                )}
              </div>

              {school.desc && (
                <p class="mt-4 text-sm font-semibold">
                  <span class="gradient-text">{school.desc}</span>
                </p>
              )}

              {school.descBullets && (
                <ul class="mt-4 space-y-3">
                  {school.descBullets.map(bullet => (
                    <li class="flex items-start gap-3">
                      <span
                        class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full"
                        style="background: linear-gradient(to right, #0ea5e9, #8b5cf6);"
                        aria-hidden="true"
                      />
                      <span class="text-sub text-[0.9rem] leading-relaxed">
                        {bullet}
                      </span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
