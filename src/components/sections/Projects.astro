---
import {freelanceProjects} from "../../data/portfolio";

const base = import.meta.env.BASE_URL;
---

<section id="projects" class="section">
  <div class="section-inner">
    <h2
      class="gradient-heading text-3xl md:text-4xl font-bold mb-2 text-center reveal"
    >
      {freelanceProjects.title}
    </h2>
    <p
      class="text-center text-sm font-semibold uppercase tracking-wider mb-10 reveal"
      style="color: var(--text-sub);"
    >
      {freelanceProjects.subtitle}
    </p>

    <div data-stagger class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        freelanceProjects.projects.map(project => (
          <div
            class="reveal flex flex-col rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
            style="background: var(--card-bg); box-shadow: var(--shadow); border: 1px solid var(--card-border);"
          >
            {project.image && (
              <div class="flex justify-center pt-6 pb-2 px-6">
                <img
                  src={`${base}/images/${project.image}`}
                  alt={project.projectName}
                  data-motion-zoom
                  class="w-20 h-20 rounded-xl object-contain bg-white p-2 shadow-sm"
                  loading="lazy"
                />
              </div>
            )}

            <div class="flex flex-col flex-1 p-6 pt-3">
              <h3 class="font-bold text-base mb-3 leading-snug">
                {project.projectName}
              </h3>
              {project.descBullets && (
                <ul class="space-y-1.5 mt-auto">
                  {project.descBullets.map(bullet => (
                    <li
                      class="flex items-start gap-2 text-sm"
                      style="color: var(--text-sub);"
                    >
                      <span class="mt-0.5 text-primary shrink-0">▸</span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
