---
import {getContent} from "../../data/portfolio";

const t = getContent(Astro.currentLocale).projects;
const base = import.meta.env.BASE_URL;

// Parse "Role:" / "Tech:" bullet lines into tags, keep the rest as prose.
const cards = t.items.map(project => {
  const bullets = project.descBullets ?? [];
  let role = "";
  let tech: string[] = [];
  const desc: string[] = [];

  for (const bullet of bullets) {
    const roleMatch = bullet.match(/^\s*Role:\s*(.+)$/i);
    const techMatch = bullet.match(/^\s*Tech:\s*(.+)$/i);
    if (roleMatch) {
      role = roleMatch[1].trim();
    } else if (techMatch) {
      tech = techMatch[1]
        .split(",")
        .map(t => t.trim())
        .filter(Boolean);
    } else {
      desc.push(bullet);
    }
  }

  return {...project, role, tech, desc};
});
---

<section id="projects" class="section reveal">
  <div class="max-w-2xl mb-12">
    <span class="eyebrow mb-3">{t.eyebrow}</span>
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight mt-3 mb-3">
      {t.headingPre}
      <span class="gradient-text">{t.headingEm}</span>
    </h2>
    <p class="text-sub text-base md:text-lg">{t.subtitle}</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-7">
    {
      cards.map((project, i) => (
        <article
          class="group reveal relative flex flex-col p-6 md:p-7 glass transition-all duration-500 hover:-translate-y-1.5"
          style={`transition-delay:${i * 90}ms`}
        >
          <div
            class="pointer-events-none absolute -inset-px -z-10 rounded-[2rem] bg-gradient-to-br from-sky-400/0 via-violet-400/0 to-fuchsia-400/0 opacity-0 blur-2xl transition-opacity duration-500 group-hover:from-sky-400/25 group-hover:via-violet-400/20 group-hover:to-fuchsia-400/25 group-hover:opacity-100"
            aria-hidden="true"
          />

          {project.image && (
            <div class="mb-5 w-16 h-16 rounded-2xl overflow-hidden bg-white shadow-sm ring-1 ring-slate-900/5 flex items-center justify-center">
              <img
                src={`${base}images/${project.image}`}
                alt={project.projectName}
                class="w-full h-full object-contain p-2.5"
                loading="lazy"
                decoding="async"
              />
            </div>
          )}

          <h3 class="font-semibold text-lg leading-snug mb-3">
            {project.projectName}
          </h3>

          {(project.role || project.tech.length > 0) && (
            <div class="flex flex-wrap gap-2 mb-4">
              {project.role && <span class="pill">{project.role}</span>}
              {project.tech.map(t => (
                <span class="pill">{t}</span>
              ))}
            </div>
          )}

          {project.desc.length > 0 && (
            <p class="text-sub text-sm leading-relaxed mt-auto">
              {project.desc.join(" ")}
            </p>
          )}
        </article>
      ))
    }
  </div>
</section>
