---
import {contactInfo, socialMediaLinks} from "../../data/portfolio";
---

<section id="contact" class="section reveal">
  <div class="relative isolate mx-auto max-w-3xl">
    <!-- Layered background glow -->
    <div
      class="pointer-events-none absolute -inset-10 -z-10 overflow-visible"
      aria-hidden="true"
    >
      <div
        class="blob absolute left-1/4 top-0 h-64 w-64 -translate-x-1/2 rounded-full bg-sky-400/30 blur-3xl"
      >
      </div>
      <div
        class="blob absolute left-1/2 top-10 h-72 w-72 -translate-x-1/2 rounded-full bg-violet-500/30 blur-3xl"
        style="animation-delay:-5s"
      >
      </div>
      <div
        class="blob absolute right-1/4 bottom-0 h-64 w-64 translate-x-1/2 rounded-full bg-fuchsia-400/30 blur-3xl"
        style="animation-delay:-9s"
      >
      </div>
    </div>

    <div
      class="glass flex flex-col items-center text-center px-6 py-14 md:px-14 md:py-20"
    >
      <span class="eyebrow mb-4">Get in touch</span>
      <h2
        class="text-3xl md:text-5xl font-bold tracking-tight mb-5 leading-tight"
      >
        Have an idea worth <span class="gradient-text">building?</span>
      </h2>
      <p class="text-sub text-base md:text-lg max-w-xl mb-8">
        {contactInfo.subtitle}
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3 mb-6">
        <a href={`mailto:${contactInfo.email}`} class="btn-gradient">
          Email Me
        </a>
        <a
          href={socialMediaLinks.github}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-ghost"
        >
          GitHub
        </a>
        <a
          href={socialMediaLinks.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-ghost"
        >
          LinkedIn
        </a>
      </div>

      {
        contactInfo.phone && (
          <a
            href={`tel:${contactInfo.phone.replace(/[^0-9+]/g, "")}`}
            class="pill"
          >
            {contactInfo.phone}
          </a>
        )
      }
    </div>
  </div>
</section>
