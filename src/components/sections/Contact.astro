---
import { contactInfo } from "../../data/portfolio";
import SocialMedia from "../SocialMedia.astro";
import LottiePlayer from "../LottiePlayer.astro";
---

<section
  id="contact"
  class="section"
  style="background: var(--bg-secondary);"
>
  <div class="flex flex-col md:flex-row items-center gap-12 max-w-4xl mx-auto">
    <div class="flex-1 reveal">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{contactInfo.title}</h2>
      <p class="text-lg mb-6" style="color: var(--text-sub);">{contactInfo.subtitle}</p>

      <div class="flex flex-col gap-2 mb-6">
        <a
          href={`mailto:${contactInfo.email}`}
          class="text-xl font-semibold text-primary hover:text-primary-hover transition-colors"
        >
          {contactInfo.email}
        </a>
        {contactInfo.phone && (
          <a
            href={`tel:${contactInfo.phone}`}
            class="text-lg font-medium hover:text-primary transition-colors"
            style="color: var(--text-sub);"
          >
            {contactInfo.phone}
          </a>
        )}
      </div>

      <SocialMedia />
    </div>

    <div class="flex-1 flex justify-center reveal-right">
      <LottiePlayer src="lottie/email.json" class="w-full max-w-xs" />
    </div>
  </div>
</section>
