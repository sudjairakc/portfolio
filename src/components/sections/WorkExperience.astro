---
import {workExperiences} from "../../data/portfolio";

const base = import.meta.env.BASE_URL;
---

<section
  id="experience"
  class="section"
  style="background: var(--bg-secondary);"
>
  <div class="max-w-4xl mx-auto">
    <h2
      class="gradient-heading text-3xl md:text-4xl font-bold mb-10 text-center reveal"
    >
      Experience
    </h2>

    <div data-stagger class="space-y-6">
      {
        workExperiences.map(card => (
          <div
            class="reveal rounded-2xl overflow-hidden transition-shadow hover:shadow-xl"
            style="background: var(--card-bg); box-shadow: var(--shadow); border: 1px solid var(--card-border);"
          >
            <div
              class="relative h-20 flex items-center px-6 gap-4"
              style="background: linear-gradient(135deg, rgba(236,79,158,0.15), rgba(236,79,158,0.05));"
            >
              <a
                href={card.link ?? "#"}
                target={card.link ? "_blank" : undefined}
                rel="noopener noreferrer"
                class="shrink-0"
              >
                <img
                  src={`${base}/images/${card.companyLogo}`}
                  alt={card.company}
                  data-motion-zoom
                  class="w-14 h-14 rounded-xl object-contain bg-white p-1.5 shadow-sm"
                  loading="lazy"
                />
              </a>
              <h3 class="font-bold text-lg leading-tight">{card.company}</h3>
            </div>

            <div class="px-6 py-5">
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <span class="text-primary font-semibold">{card.role}</span>
                <span
                  class="text-xs px-3 py-1 rounded-full"
                  style="background: var(--bg-secondary); color: var(--text-sub);"
                >
                  {card.date}
                </span>
              </div>

              {card.desc && (
                <p class="text-sm mb-2" style="color: var(--text-sub);">
                  {card.desc}
                </p>
              )}

              {card.descBullets && (
                <ul class="space-y-1.5">
                  {card.descBullets.map(bullet => (
                    <li
                      class="flex items-start gap-2 text-sm"
                      style="color: var(--text-sub);"
                    >
                      <span class="mt-0.5 text-primary shrink-0">▸</span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
