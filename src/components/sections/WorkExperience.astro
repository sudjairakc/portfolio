---
import {workExperiences} from "../../data/portfolio";

const base = import.meta.env.BASE_URL;
---

<section id="experience" class="section reveal">
  <!-- Heading block -->
  <div class="max-w-2xl">
    <span class="eyebrow">Experience</span>
    <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight">
      Work <span class="gradient-text">experience</span>
    </h2>
    <p class="text-sub mt-4 text-base leading-relaxed">
      Roles where I owned features end-to-end and led when it mattered.
    </p>
  </div>

  <!-- Timeline -->
  <div class="relative mt-12">
    <!-- vertical rail -->
    <span
      class="pointer-events-none absolute left-[9px] top-2 bottom-2 w-px sm:left-[11px]"
      style="background: linear-gradient(to bottom, rgba(14,165,233,0.5), rgba(139,92,246,0.5), rgba(217,70,239,0.1));"
      aria-hidden="true"></span>

    <ol class="space-y-8">
      {
        workExperiences.map(exp => (
          <li class="relative pl-10 sm:pl-12 reveal-right">
            {/* node dot */}
            <span
              class="absolute left-0 top-2 flex h-5 w-5 items-center justify-center sm:h-6 sm:w-6"
              aria-hidden="true"
            >
              <span
                class="h-3 w-3 rounded-full ring-4 ring-white dark:ring-slate-900"
                style="background: linear-gradient(to right, #0ea5e9, #8b5cf6);"
              />
            </span>

            <article class="glass p-6 sm:p-8 transition duration-300 ease-out hover:-translate-y-1 hover:shadow-2xl">
              {/* header row */}
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex items-start gap-4 min-w-0">
                  {exp.companyLogo && (
                    <img
                      src={`${base}images/${exp.companyLogo}`}
                      alt={exp.company}
                      loading="lazy"
                      class="h-12 w-12 shrink-0 rounded-xl object-contain bg-white p-1.5 shadow-sm ring-1 ring-black/5"
                    />
                  )}
                  <div class="min-w-0">
                    <h3 class="text-lg font-semibold tracking-tight">
                      {exp.role}
                    </h3>
                    <p class="text-sub mt-0.5 text-[0.95rem]">
                      {exp.link ? (
                        <a
                          href={exp.link}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="transition-colors hover:text-sky-500"
                        >
                          {exp.company}
                        </a>
                      ) : (
                        exp.company
                      )}
                    </p>
                  </div>
                </div>

                <span class="pill shrink-0 self-start whitespace-nowrap">
                  {exp.date}
                </span>
              </div>

              {/* body */}
              {exp.descBullets ? (
                <ul class="mt-5 space-y-3">
                  {exp.descBullets.map(bullet => (
                    <li class="flex items-start gap-3">
                      <span
                        class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full"
                        style="background: linear-gradient(to right, #0ea5e9, #8b5cf6);"
                        aria-hidden="true"
                      />
                      <span class="text-sub text-[0.9rem] leading-relaxed">
                        {bullet}
                      </span>
                    </li>
                  ))}
                </ul>
              ) : (
                exp.desc && (
                  <p class="text-sub mt-5 text-[0.9rem] leading-relaxed">
                    {exp.desc}
                  </p>
                )
              )}
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>
