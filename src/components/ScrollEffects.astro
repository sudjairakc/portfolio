---
// Scroll-driven effects powered by Motion (vanilla). Include once per page.
//
//   #scroll-progress          → top progress bar, scaleX linked to page scroll
//   [data-parallax]           → translateY linked to scroll
//                               (speed via data-parallax-speed, default 60px)
//   [data-hero-content]       → Apple-style scrub: scales/fades/blurs out as the
//                               hero scrolls past (set on the hero's inner wrapper)
//   [data-stagger]            → its .reveal children fade in one-by-one
//                               (step via data-stagger-step, default 80ms)
---

<script>
  import {scroll} from "motion";

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Top scroll-progress bar — runs even with reduced motion (it's an indicator,
  // not a movement effect) but is cheap and non-distracting.
  const progress = document.querySelector<HTMLElement>("#scroll-progress");
  if (progress) {
    scroll((p: number) => {
      progress.style.transform = `scaleX(${p})`;
    });
  }

  // Stagger: sequence the .reveal children of a [data-stagger] container so
  // they fade in one-by-one rather than all at once. Works with the existing
  // .reveal CSS transition in global.css.
  document.querySelectorAll<HTMLElement>("[data-stagger]").forEach(group => {
    const step = Number(group.dataset.staggerStep ?? 80);
    group
      .querySelectorAll<HTMLElement>(".reveal, .reveal-left, .reveal-right")
      .forEach((child, i) => {
        // cap the cascade so long lists don't wait too long
        child.style.transitionDelay = `${Math.min(i, 8) * step}ms`;
      });
  });

  if (!reduce) {
    // Parallax: element drifts as it crosses the viewport.
    document.querySelectorAll<HTMLElement>("[data-parallax]").forEach(el => {
      const speed = Number(el.dataset.parallaxSpeed ?? 60);
      scroll(
        (p: number) => {
          // p: 0 when element enters bottom, 1 when it leaves top
          el.style.transform = `translateY(${(0.5 - p) * speed * 2}px)`;
        },
        {target: el, offset: ["start end", "end start"]}
      );
    });

    // Hero scrub: content recedes (scale + fade + blur) as you scroll away.
    document
      .querySelectorAll<HTMLElement>("[data-hero-content]")
      .forEach(el => {
        const hero = el.closest<HTMLElement>("[data-hero]") ?? el;
        scroll(
          (p: number) => {
            el.style.transform = `scale(${1 - p * 0.12})`;
            el.style.opacity = `${1 - p * 1.15}`;
            el.style.filter = `blur(${p * 6}px)`;
          },
          {target: hero, offset: ["start start", "end start"]}
        );
      });
  }
</script>
