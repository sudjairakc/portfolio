---
// Shared page body for every locale. Section components read the active
// language from Astro.currentLocale (set by the route), so this is identical
// across /  (en) and /th/.
import Navbar from "./Navbar.astro";
import Hero from "./Hero.astro";
import Skills from "./sections/Skills.astro";
import Education from "./sections/Education.astro";
import WorkExperience from "./sections/WorkExperience.astro";
import AICollaboration from "./sections/AICollaboration.astro";
import Projects from "./sections/Projects.astro";
import Contact from "./sections/Contact.astro";
import Footer from "./Footer.astro";
---

<Navbar />

<main>
  <Hero />
  <Skills />
  <Education />
  <WorkExperience />
  <AICollaboration />
  <Projects />
  <Contact />
</main>

<Footer />

<!-- Scroll-to-top button -->
<button
  id="scroll-top"
  aria-label="Scroll to top"
  class="glass fixed bottom-6 right-6 z-40 flex h-11 w-11 !rounded-full items-center justify-center opacity-0 transition-opacity duration-300 pointer-events-none"
>
  <i class="fas fa-arrow-up text-sm"></i>
</button>

<script is:inline>
  const btn = document.getElementById("scroll-top");
  if (btn) {
    window.addEventListener("scroll", () => {
      const show = window.scrollY > 400;
      btn.style.opacity = show ? "1" : "0";
      btn.style.pointerEvents = show ? "auto" : "none";
    });
    btn.addEventListener("click", () =>
      window.scrollTo({top: 0, behavior: "smooth"})
    );
  }
</script>
