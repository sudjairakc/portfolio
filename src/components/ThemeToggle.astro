<button
  class="theme-toggle relative w-12 h-6 rounded-full transition-colors duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
  aria-label="Toggle dark mode"
  style="background: var(--card-border)"
>
  <span
    class="toggle-knob absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform duration-300 flex items-center justify-center text-xs"
  >
    <i class="toggle-icon fas fa-sun text-yellow-400"></i>
  </span>
</button>

<script>
  const html = document.documentElement;

  function syncAll() {
    const dark = html.classList.contains("dark");
    document.querySelectorAll<HTMLElement>(".theme-toggle").forEach(btn => {
      btn.style.background = dark ? "#ec4f9e" : "rgba(0,0,0,0.15)";
      const knob = btn.querySelector<HTMLElement>(".toggle-knob");
      const icon = btn.querySelector<HTMLElement>(".toggle-icon");
      if (knob)
        knob.style.transform = dark ? "translateX(24px)" : "translateX(0)";
      if (icon)
        icon.className = dark
          ? "toggle-icon fas fa-moon text-white"
          : "toggle-icon fas fa-sun text-yellow-400";
    });
  }

  syncAll();

  document.querySelectorAll<HTMLElement>(".theme-toggle").forEach(btn => {
    btn.addEventListener("click", () => {
      html.classList.toggle("dark");
      localStorage.setItem("isDark", String(html.classList.contains("dark")));
      syncAll();
    });
  });
</script>
