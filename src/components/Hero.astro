---
import {getContent, socialMediaLinks, heroChips} from "../data/portfolio";

const t = getContent(Astro.currentLocale).hero;

const socials = [
  {
    label: "GitHub",
    href: socialMediaLinks.github,
    icon: "M12 .5C5.73.5.5 5.73.5 12.02c0 5.1 3.29 9.42 7.86 10.95.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.68 0-1.25.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.74.8 1.19 1.83 1.19 3.08 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.06.78 2.14 0 1.55-.02 2.8-.02 3.18 0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.02C23.5 5.73 18.27.5 12 .5Z"
  },
  {
    label: "LinkedIn",
    href: socialMediaLinks.linkedin,
    icon: "M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"
  },
  {
    label: "GitLab",
    href: socialMediaLinks.gitlab,
    icon: "M23.6 9.6 23.57 9.5 20.3.9a.85.85 0 0 0-.83-.57.83.83 0 0 0-.8.6l-2.2 6.75H7.53L5.32.93a.83.83 0 0 0-.8-.6.85.85 0 0 0-.82.57L.43 9.5.4 9.6a6.06 6.06 0 0 0 2 7l.02.01.03.02 4.96 3.72 2.46 1.86 1.5 1.13a.98.98 0 0 0 1.18 0l1.5-1.13 2.46-1.86 5-3.74.01-.01a6.06 6.06 0 0 0 2-7Z"
  },
  {
    label: "Facebook",
    href: socialMediaLinks.facebook,
    icon: "M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07Z"
  },
  {
    label: "Email",
    href: `mailto:${socialMediaLinks.gmail}`,
    icon: "M22 4H2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h20a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm-.4 4.25-8.53 5.33a2 2 0 0 1-2.14 0L2.4 8.25a.75.75 0 1 1 .8-1.27L12 12.02l8.8-5.04a.75.75 0 1 1 .8 1.27Z"
  }
];
---

<section id="home" class="relative overflow-hidden">
  <!-- Drifting AI-orb blobs -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 overflow-hidden"
  >
    <div
      class="blob float-slower absolute -top-24 -left-16 h-80 w-80 rounded-full bg-sky-400/25 blur-3xl dark:bg-sky-500/20"
    >
    </div>
    <div
      class="blob absolute top-10 right-0 h-96 w-96 rounded-full bg-violet-400/25 blur-3xl dark:bg-violet-500/20"
    >
    </div>
    <div
      class="blob float-slow absolute -bottom-24 left-1/3 h-72 w-72 rounded-full bg-emerald-400/20 blur-3xl dark:bg-emerald-500/15"
    >
    </div>
  </div>

  <div class="section pt-32 lg:pt-36">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- LEFT -->
      <div class="reveal">
        <span class="eyebrow">
          <span class="relative flex h-2.5 w-2.5">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500"
            ></span>
          </span>
          {t.badge}
        </span>

        <h1
          class="mt-5 text-4xl font-extrabold leading-tight sm:text-5xl lg:text-6xl"
        >
          {t.greetingPre}
          <span class="gradient-text">{t.greetingName}</span>{t.greetingPost}
        </h1>

        <p class="text-sub mt-6 max-w-xl leading-relaxed">
          {t.subTitle}
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href={t.resumeLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-gradient"
          >
            {t.resumeBtn}
          </a>
          <a
            href={socialMediaLinks.github}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-ghost"
          >
            {t.githubBtn}
          </a>
          <a href="#contact" class="btn-ghost">{t.contactBtn}</a>
        </div>

        <!-- Social icons -->
        <div class="mt-8 flex flex-wrap items-center gap-3">
          {
            socials.map(s => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-300/60 bg-white/50 text-slate-500 backdrop-blur transition hover:-translate-y-0.5 hover:text-slate-900 hover:shadow-lg dark:border-white/10 dark:bg-white/5 dark:text-slate-400 dark:hover:text-white"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="h-[18px] w-[18px]"
                  aria-hidden="true"
                >
                  <path d={s.icon} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>

      <!-- RIGHT -->
      <div class="reveal-right lg:justify-self-end">
        <div class="glass float-slow w-full max-w-sm p-7">
          <!-- Avatar tile -->
          <div class="flex items-center gap-4">
            <div
              class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-sky-500 to-violet-500 font-mono text-2xl font-bold text-white shadow-lg"
            >
              &lt;/&gt;
            </div>
            <div>
              <p class="font-mono text-lg font-semibold">
                &lt; ChaichanaS /&gt;
              </p>
              <p class="text-sub text-sm">{t.cardRole}</p>
            </div>
          </div>

          <!-- Skill chips -->
          <div class="mt-6 flex flex-wrap gap-2">
            {heroChips.map(c => <span class="pill">{c}</span>)}
          </div>

          <!-- Stat lines -->
          <div
            class="mt-6 space-y-2.5 border-t border-slate-200/60 pt-5 dark:border-white/10"
          >
            {
              t.stats.map(stat => (
                <div class="flex items-center gap-2.5 text-sm">
                  <span class="h-1.5 w-1.5 rounded-full bg-gradient-to-r from-sky-400 to-violet-400" />
                  <span class="font-medium">{stat}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
