---

<footer class="border-t border-slate-900/10 dark:border-white/10 mt-8">
  <div
    class="section !py-8 flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between"
  >
    <div class="flex flex-col gap-1 text-center sm:text-left">
      <span class="font-mono text-sm font-semibold gradient-text"
        >&lt; ChaichanaS /&gt;</span
      >
      <span class="text-sub text-xs"
        >AI-focused Full Stack Developer · Thailand</span
      >
    </div>

    <div class="flex items-center justify-center gap-2">
      {
        socials.map(s => (
          <a
            href={s.href}
            aria-label={s.label}
            target={s.href.startsWith("mailto:") ? undefined : "_blank"}
            rel={s.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
            class="text-slate-400 hover:text-slate-900 dark:text-slate-500 dark:hover:text-white transition-colors p-2"
          >
            <svg
              viewBox="0 0 24 24"
              class="w-5 h-5"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d={s.path} />
            </svg>
          </a>
        ))
      }
    </div>
  </div>

  <div class="section !py-0 pb-8">
    <p class="text-sub text-xs text-center">
      © 2026 Chaichana Sudjairak. Built with Astro &amp; Tailwind.
    </p>
  </div>
</footer>
