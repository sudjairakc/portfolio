---
interface Props {
  src: string;
  class?: string;
  id?: string;
}

const { src, class: className, id } = Astro.props;
const uniqueId = id ?? `lottie-${Math.random().toString(36).slice(2, 8)}`;
const base = import.meta.env.BASE_URL;
---

<div id={uniqueId} class={className} data-lottie={`${base}/${src}`}></div>

<script>
  import lottie from "lottie-web";

  document.querySelectorAll<HTMLElement>("[data-lottie]").forEach((el) => {
    const path = el.dataset.lottie!;
    lottie.loadAnimation({
      container: el,
      renderer: "svg",
      loop: true,
      autoplay: true,
      path,
    });
  });
</script>
