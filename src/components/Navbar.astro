---
import { socialMediaLinks, greeting } from "../data/portfolio";

const links = [
  { label: "Skills", href: "#skills" },
  { label: "Experience", href: "#experience" },
  { label: "Projects", href: "#projects" },
  { label: "Contact", href: "#contact" }
];
---

<header class="fixed inset-x-0 top-0 z-50 px-4 pt-4">
  <nav
    class="glass mx-auto flex max-w-4xl items-center justify-between gap-4 !rounded-full px-4 py-2.5 sm:px-6"
    aria-label="Primary"
  >
    <!-- Logo -->
    <a
      href="#home"
      class="font-mono text-sm font-bold tracking-tight sm:text-base"
    >
      &lt; <span class="gradient-text">{greeting.username}</span> /&gt;
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-1 md:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="rounded-full px-3 py-1.5 text-sm font-medium text-slate-600 transition hover:bg-white/60 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-white/10 dark:hover:text-white"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="flex h-9 w-9 items-center justify-center rounded-full border border-slate-300/60 bg-white/40 text-slate-700 transition hover:bg-white/70 dark:border-white/10 dark:bg-white/5 dark:text-slate-200 dark:hover:bg-white/10"
      >
        <!-- sun (shown in dark mode) -->
        <svg
          class="hidden h-4 w-4 dark:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
          ></path>
        </svg>
        <!-- moon (shown in light mode) -->
        <svg
          class="block h-4 w-4 dark:hidden"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <a
        href={socialMediaLinks.github}
        target="_blank"
        rel="noopener"
        class="btn-primary !px-4 !py-2 !text-sm"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.96 0-1.32.47-2.39 1.24-3.23-.13-.3-.54-1.53.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.65.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.23 0 4.63-2.8 5.65-5.48 5.95.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"
          ></path></svg
        >
        <span class="hidden sm:inline">View GitHub</span>
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("isDark", String(isDark));
  });
</script>
