---
// Wires Motion (vanilla) hover/press spring animations onto any element
// marked with `data-motion-btn`. Include once near the end of the page.
---

<script>
  import {animate, hover, press} from "motion";

  const SPRING = {type: "spring", stiffness: 400, damping: 17} as const;
  const ZOOM_SPRING = {type: "spring", stiffness: 300, damping: 22} as const;

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reduce) {
    document.querySelectorAll<HTMLElement>("[data-motion-btn]").forEach(el => {
      // springy lift on hover
      hover(el, element => {
        animate(element, {scale: 1.05}, SPRING);
        return () => animate(element, {scale: 1}, SPRING);
      });

      // quick squish on press, release back to rest
      press(el, element => {
        animate(element, {scale: 0.94}, {duration: 0.12});
        return () => animate(element, {scale: 1}, SPRING);
      });
    });

    // Hover-to-zoom for images (scale within a clipped frame looks best).
    document.querySelectorAll<HTMLElement>("[data-motion-zoom]").forEach(el => {
      hover(el, element => {
        animate(element, {scale: 1.12}, ZOOM_SPRING);
        return () => animate(element, {scale: 1}, ZOOM_SPRING);
      });
    });
  }
</script>
