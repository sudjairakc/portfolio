---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SplashScreen from "../components/SplashScreen.astro";
import Greeting from "../components/sections/Greeting.astro";
import Skills from "../components/sections/Skills.astro";
import Education from "../components/sections/Education.astro";
import WorkExperience from "../components/sections/WorkExperience.astro";
import Projects from "../components/sections/Projects.astro";
import Contact from "../components/sections/Contact.astro";
import "../styles/global.css";

import {splashScreen} from "../data/portfolio";
---

<Layout>
  {splashScreen.enabled && <SplashScreen />}

  <Header />

  <main>
    <Greeting />
    <Skills />
    <Education />
    <WorkExperience />
    <Projects />
    <Contact />
  </main>

  <Footer />

  <!-- Scroll-to-top button -->
  <button
    id="scroll-top"
    aria-label="Scroll to top"
    class="fixed bottom-6 right-6 w-10 h-10 rounded-full bg-primary text-white shadow-lg opacity-0 pointer-events-none transition-all duration-300 hover:bg-primary-hover hover:scale-110 flex items-center justify-center z-40"
  >
    <i class="fas fa-arrow-up text-sm"></i>
  </button>
</Layout>

<script>
  const btn = document.getElementById("scroll-top")!;

  window.addEventListener("scroll", () => {
    if (window.scrollY > 300) {
      btn.style.opacity = "1";
      btn.style.pointerEvents = "auto";
    } else {
      btn.style.opacity = "0";
      btn.style.pointerEvents = "none";
    }
  });

  btn.addEventListener("click", () =>
    window.scrollTo({top: 0, behavior: "smooth"})
  );
</script>
